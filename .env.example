# Supabase project URL (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anonymous/public key (Settings → API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key for server-side admin operations (keep secret)
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth client ID (Google Cloud Console → Credentials)
GOOGLE_CLIENT_ID=

# Google OAuth client secret (Google Cloud Console → Credentials)
GOOGLE_CLIENT_SECRET=

# OpenAI API key for AI features
OPENAI_API_KEY=

# Random secret for signing NextAuth session tokens (e.g. openssl rand -base64 32)
NEXTAUTH_SECRET=

# Base URL of the app for NextAuth callbacks
NEXTAUTH_URL=http://localhost:3000
